<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_toolbar"
            android:elevation="10dp"
            android:translationZ="10dp"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <!-- Flecha de Regreso -->
            <ImageView
                android:id="@+id/btnRegresar"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Regresar"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#FFFFFF" />

            <!-- Menú Hamburguesa -->
            <ImageView
                android:id="@+id/btnMenuLateral"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Menú"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFFFFF" />

            <!-- Espaciador flexible -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Grupo Derecho: Iconos y Avatar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Icono Calendario -->
                <ImageView
                    android:id="@+id/btnIconoCalendario"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Calendario"
                    android:src="@drawable/ic_calendar"
                    app:tint="#FFFFFF" />

                <!-- Icono Notificaciones -->
                <ImageView
                    android:id="@+id/btnIconoNotificaciones"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Notificaciones"
                    android:src="@drawable/ic_notification"
                    app:tint="#FFFFFF" />

                <!-- Avatar Usuario -->
                <TextView
                    android:id="@+id/btnAvatarUsuario"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/avatar_circular"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="JM"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>



        <!-- CARD 1: INFORMACIÓN DEL PERFIL -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Perfil"
                    android:textColor="#333"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/avatar_circular"
                    android:gravity="center"
                    android:text="JM"
                    android:textColor="#FFF"
                    android:textSize="34sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:text="Juan Manuel Tovar"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_badge"
                    android:padding="4dp"
                    android:text="Docente"
                    android:textColor="#FFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#D9F4FF"
                    app:cardCornerRadius="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:text="Los datos personales no pueden ser modificados. Solo puedes cambiar tu contraseña o foto de perfil."
                        android:textSize="14sp" />

                </androidx.cardview.widget.CardView>

                <!-- Nombre -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="6dp"
                    android:text="Nombre(s)"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Nombre(s)"
                    android:background="@drawable/bg_edittext"
                    android:enabled="false"
                    android:padding="12dp" />

                <!-- Apellido paterno -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Apellido Paterno"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etApellidoPaterno"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Apellido Paterno"
                    android:background="@drawable/bg_edittext"
                    android:enabled="false"
                    android:padding="12dp" />

                <!-- Carrera -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Carrera"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCarrera"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Carrera"
                    android:background="@drawable/bg_edittext"
                    android:enabled="false"
                    android:padding="12dp" />

                <!-- Departamento -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Departamento"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDepartamento"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edittext"
                    android:enabled="false"
                    android:padding="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD 2: CAMBIAR CONTRASEÑA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cambiar Contraseña"
                    android:textColor="#333333"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Contraseña Actual -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"
                    android:text="Contraseña Actual"
                    android:textColor="#444444"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPasswordActual"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edittext"
                    android:drawableStart="@drawable/ic_lock"
                    android:drawablePadding="10dp"
                    android:inputType="textPassword"
                    android:padding="12dp" />

                <!-- Nueva Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"
                    android:text="Nueva Contraseña"
                    android:textColor="#444444"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNuevaPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edittext"
                    android:drawableStart="@drawable/ic_lock"
                    android:drawablePadding="10dp"
                    android:inputType="textPassword"
                    android:padding="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="La contraseña debe tener al menos 8 caracteres."
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <!-- Confirmar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"
                    android:text="Confirmar Nueva Contraseña"
                    android:textColor="#444444"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etConfirmarPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edittext"
                    android:drawableStart="@drawable/ic_check_circle"
                    android:drawablePadding="10dp"
                    android:inputType="textPassword"
                    android:padding="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnVolver"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#0D9488"
                android:text="Volver"
                android:textColor="#FFF" />

            <Button
                android:id="@+id/btnActualizar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#16A34A"
                android:text="Actualizar"
                android:textColor="#FFF" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>